# Copy this file to .env and fill in values. .env is git-ignored.
# Every variable is optional — the app degrades gracefully when unset:
#   - No Graph creds → local-folder scanning only (graph_access=false)
#   - No OpenRouter creds / GDPR_ALLOW_EXTERNAL_LLM≠1 → deterministic Tier-2 stub

# ── Microsoft Graph / OneDrive (app-only client credentials) ──────────────────
# Azure app registration with Files.Read.All APPLICATION permission + admin consent.
# See: https://learn.microsoft.com/en-us/graph/auth-v2-service
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
# Target OneDrive drive id (e.g. b!Abc123...). Leave blank to resolve via GRAPH_USER_ID.
GRAPH_DRIVE_ID=
# Optional: resolve drive via /users/{id}/drive when GRAPH_DRIVE_ID is unset.
GRAPH_USER_ID=
# Override for sovereign / national clouds (default: https://login.microsoftonline.com)
GRAPH_AUTHORITY=https://login.microsoftonline.com
# Override Graph REST base URL (default: https://graph.microsoft.com/v1.0)
GRAPH_BASE_URL=https://graph.microsoft.com/v1.0

# ── OpenRouter (Tier-2 LLM/VLM confirmation) ─────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your_key_here
# Model used for Tier-2 classification. Any model that supports structured outputs.
OPENROUTER_MODEL=anthropic/claude-3.5-haiku
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_S=30
# Safety gate: Tier-2 sends context to a THIRD-PARTY API.
# Must be explicitly set to 1 to enable (demo / synthetic data only).
# Production deployments should use in-perimeter inference instead.
GDPR_ALLOW_EXTERNAL_LLM=1
# Max Tier-2 escalations per explicit pass (maps to EscalationPolicy budget).
TIER2_BUDGET=100

# ── Engine / runtime overrides ────────────────────────────────────────────────
# Override catalog DB path (default: data/catalog.sqlite relative to repo root)
GDPR_DB_PATH=
# Override YOLO ONNX model path (default: data/models/yolo11n.onnx)
GDPR_YOLO_ONNX=
# CORS allow-list for the FastAPI backend (default: http://localhost:5173)
CORS_ORIGINS=http://localhost:5173
# Override scan.yaml cpu_budget_pct (0 = use yaml / code default of 30)
SCAN_CPU_BUDGET_PCT=
# Override scan.yaml max_workers (0 = auto-compute from cpu_budget_pct)
SCAN_MAX_WORKERS=
