          </w:tcPr>
          <w:p w14:paraId="3B8E54DC" w14:textId="77777777" w:rsidR="00823C55" w:rsidRPr="00823C55" w:rsidRDefault="00823C55" w:rsidP="00823C55">
            <w:pPr>
              <w:rPr>
                <w:lang w:val="en-GB"/>
              </w:rPr>
            </w:pPr>
            <w:r>
              <w:rPr>
                <w:lang w:val="en-GB"/>
              </w:rPr>
              <w:t>Principles relating to processing of personal data</w:t>
            </w:r>
          </w:p>
        </w:tc>
        <w:tc>
          <w:tcPr>
            <w:tcW w:w="0" w:type="auto"/>
            <w:vAlign w:val="center"/>
            <w:hideMark/>
          </w:tcPr>
          <w:p w14:paraId="5E5A4CEB" w14:textId="77777777" w:rsidR="00823C55" w:rsidRPr="00823C55" w:rsidRDefault="00823C55" w:rsidP="00823C55">
            <w:pPr>
              <w:rPr>
                <w:lang w:val="en-GB"/>
              </w:rPr>
            </w:pPr>
            <w:r>
              <w:rPr>
                <w:lang w:val="en-GB"/>
              </w:rPr>
              <w:t>This article sets the core principles. For data management, data minimisation (only process necessary data) and storage limitation (don't store data longer than needed) are crucial. Tools help enforce this by identifying and deleting obsolete data.</w:t>
            </w:r>
          </w:p>
        </w:tc>
      </w:tr>
      <w:tr w:rsidR="00823C55" w:rsidRPr="00823C55" w14:paraId="7C5FB792" w14:textId="77777777" w:rsidTr="00823C55">
        <w:trPr>
          <w:tblCellSpacing w:w="15" w:type="dxa"/>
        </w:trPr>
        <w:tc>
          <w:tcPr>
            <w:tcW w:w="1089" w:type="dxa"/>
            <w:vAlign w:val="center"/>
            <w:hideMark/>
          </w:tcPr>
          <w:p w14:paraId="131B0AE2" w14:textId="77777777" w:rsidR="00823C55" w:rsidRPr="00823C55" w:rsidRDefault="00823C55" w:rsidP="00823C55">
            
            <w:r>
              <w:t>Article 17</w:t>
            </w:r>
            
            
          </w:p>
        </w:tc>
        <w:tc>
          <w:tcPr>
            <w:tcW w:w="1543" w:type="dxa"/>
            <w:vAlign w:val="center"/>
            <w:hideMark/>
          </w:tcPr>
          <w:p w14:paraId="0F7D487C" w14:textId="77777777" w:rsidR="00823C55" w:rsidRPr="00823C55" w:rsidRDefault="00823C55" w:rsidP="00823C55">
            <w:pPr>
              <w:rPr>
                <w:lang w:val="en-GB"/>
              </w:rPr>
            </w:pPr>
            <w:r>
              <w:rPr>
                <w:lang w:val="en-GB"/>
              </w:rPr>
              <w:t>Right to erasure ('right to be forgotten')</w:t>
            </w:r>
          </w:p>
        </w:tc>
        <w:tc>
          <w:tcPr>
            <w:tcW w:w="0" w:type="auto"/>
            <w:vAlign w:val="center"/>
            <w:hideMark/>
          </w:tcPr>
          <w:p w14:paraId="5452825B" w14:textId="77777777" w:rsidR="00823C55" w:rsidRPr="00823C55" w:rsidRDefault="00823C55" w:rsidP="00823C55">
            <w:pPr>
              <w:rPr>
                <w:lang w:val="en-GB"/>
              </w:rPr>
            </w:pPr>
            <w:r>
              <w:rPr>
                <w:lang w:val="en-GB"/>
              </w:rPr>
              <w:t>This gives individuals the right to have their personal data deleted by an organization. A data management tool is essential to fulfill these requests by finding and securely deleting the relevant data from all systems, including unstructured files.</w:t>
            </w:r>
            
            
            
            
          </w:p>
        </w:tc>
      </w:tr>
      <w:tr w:rsidR="00823C55" w:rsidRPr="00823C55" w14:paraId="36C006A1" w14:textId="77777777" w:rsidTr="00823C55">
        <w:trPr>
          <w:tblCellSpacing w:w="15" w:type="dxa"/>
        </w:trPr>
        <w:tc>
          <w:tcPr>
            <w:tcW w:w="1089" w:type="dxa"/>
            <w:vAlign w:val="center"/>
            <w:hideMark/>
          </w:tcPr>
          <w:p w14:paraId="7F12460F" w14:textId="77777777" w:rsidR="00823C55" w:rsidRPr="00823C55" w:rsidRDefault="00823C55" w:rsidP="00823C55">
            
            <w:r>
              <w:t>Article 25</w:t>
            </w:r>
            
            
          </w:p>
        </w:tc>
        <w:tc>
          <w:tcPr>
            <w:tcW w:w="1543" w:type="dxa"/>
            <w:vAlign w:val="center"/>
            <w:hideMark/>
          </w:tcPr>
          <w:p w14:paraId="7B16AE8C" w14:textId="77777777" w:rsidR="00823C55" w:rsidRPr="00823C55" w:rsidRDefault="00823C55" w:rsidP="00823C55">
            <w:pPr>
              <w:rPr>
                <w:lang w:val="en-GB"/>
              </w:rPr>
            </w:pPr>
            <w:r>
              <w:rPr>
                <w:lang w:val="en-GB"/>
              </w:rPr>
              <w:t>Data protection by design and by default</w:t>
            </w:r>
          </w:p>
        </w:tc>
        <w:tc>
          <w:tcPr>
            <w:tcW w:w="0" w:type="auto"/>
            <w:vAlign w:val="center"/>
            <w:hideMark/>
          </w:tcPr>
          <w:p w14:paraId="30332FDD" w14:textId="77777777" w:rsidR="00823C55" w:rsidRPr="00823C55" w:rsidRDefault="00823C55" w:rsidP="00823C55">
            <w:pPr>
              <w:rPr>
                <w:lang w:val="en-GB"/>
              </w:rPr>
            </w:pPr>
            <w:r>
              <w:rPr>
                <w:lang w:val="en-GB"/>
              </w:rPr>
              <w:t>This principle requires organizations to integrate data protection measures into their processing activities and systems from the very beginning. Using an automated tool to manage data lifecycles is a perfect example of implementing &quot;privacy by design.&quot;</w:t>
            </w:r>
          </w:p>
        </w:tc>
      </w:tr>
      <w:tr w:rsidR="00823C55" w:rsidRPr="00823C55" w14:paraId="7DE7A98D" w14:textId="77777777" w:rsidTr="00823C55">
        <w:trPr>
          <w:trHeight w:val="330"/>
          <w:tblCellSpacing w:w="15" w:type="dxa"/>
        </w:trPr>
        <w:tc>
          <w:tcPr>
            <w:tcW w:w="1089" w:type="dxa"/>
            <w:vAlign w:val="center"/>
            <w:hideMark/>
          </w:tcPr>
          <w:p w14:paraId="7FCB240E" w14:textId="77777777" w:rsidR="00823C55" w:rsidRPr="00823C55" w:rsidRDefault="00823C55" w:rsidP="00823C55">
            
            <w:r>
              <w:lastRenderedPageBreak/>
              <w:t>Article 32</w:t>
            </w:r>
            
            
          </w:p>
        </w:tc>
        <w:tc>
          <w:tcPr>
            <w:tcW w:w="1543" w:type="dxa"/>
            <w:vAlign w:val="center"/>
            <w:hideMark/>
          </w:tcPr>
          <w:p w14:paraId="2F33178F" w14:textId="77777777" w:rsidR="00823C55" w:rsidRPr="00823C55" w:rsidRDefault="00823C55" w:rsidP="00823C55">
            <w:r>
              <w:t>Security of processing</w:t>
            </w:r>
            
            
            
            
            
            
            
          </w:p>
        </w:tc>
        <w:tc>
          <w:tcPr>
            <w:tcW w:w="0" w:type="auto"/>
            <w:vAlign w:val="center"/>
            <w:hideMark/>
          </w:tcPr>
          <w:p w14:paraId="561BA722" w14:textId="77777777" w:rsidR="00823C55" w:rsidRPr="00823C55" w:rsidRDefault="00823C55" w:rsidP="00823C55">
            <w:pPr>
              <w:rPr>
                <w:lang w:val="en-GB"/>
              </w:rPr>
            </w:pPr>
            <w:r>
              <w:rPr>
                <w:lang w:val="en-GB"/>
              </w:rPr>
              <w:t>To properly secure personal data, you first need to know where it is. Tools that scan for and classify personal data are fundamental to understanding the risk landscape and applying appropriate security measures to protect it.</w:t>
            </w:r>
          </w:p>
        </w:tc>
      </w:tr>
    </w:tbl>
