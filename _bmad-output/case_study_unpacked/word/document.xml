          </w:tcPr>
          <w:p w14:paraId="65099462" w14:textId="77777777" w:rsidR="00823C55" w:rsidRPr="00823C55" w:rsidRDefault="00823C55" w:rsidP="00823C55">
            
            <w:r>
              <w:t>Article 5</w:t>
            </w:r>
            
            
          </w:p>
        </w:tc>
        <w:tc>
          <w:tcPr>
            <w:tcW w:w="1543" w:type="dxa"/>
