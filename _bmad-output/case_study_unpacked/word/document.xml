        <w:t>Problem Statement: GDPR and Data Management</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="3E3DFA77" w14:textId="0D203D97" w:rsidR="00153B69" w:rsidRPr="00153B69" w:rsidRDefault="00153B69" w:rsidP="00153B69">
